generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  avatarUrl String?  @map("avatar_url")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  wallet           Wallet?
  auctions         Auction[]       @relation("SellerAuctions")
  bids             Bid[]
  wonAuctions      Auction[]       @relation("WinnerAuctions")
  chatMessages     ChatMessage[]
  ratingsGiven     Rating[]        @relation("RatingsGiven")
  ratingsReceived  Rating[]        @relation("RatingsReceived")
  notifications    Notification[]
  mutedInAuctions  AuctionMute[]

  @@map("users")
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  heldBalance Decimal  @default(0) @map("held_balance") @db.Decimal(12, 2)
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String          @id @default(uuid())
  walletId    String          @map("wallet_id")
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  auctionId   String?         @map("auction_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  wallet  Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  auction Auction? @relation(fields: [auctionId], references: [id])

  @@map("wallet_transactions")
}

enum TransactionType {
  topup
  hold
  release
  debit
  credit
  refund
  withdraw
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  auctions Auction[]

  @@map("categories")
}

model Auction {
  id              String        @id @default(uuid())
  sellerId        String        @map("seller_id")
  categoryId      String?       @map("category_id")
  title           String
  description     String
  images          String[]
  startingBid     Decimal       @map("starting_bid") @db.Decimal(12, 2)
  buyNowPrice     Decimal?      @map("buy_now_price") @db.Decimal(12, 2)
  currentBid      Decimal?      @map("current_bid") @db.Decimal(12, 2)
  currentWinnerId String?       @map("current_winner_id")
  durationMinutes Int           @map("duration_minutes")
  status          AuctionStatus @default(draft)
  startsAt        DateTime      @map("starts_at")
  endsAt          DateTime      @map("ends_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  seller        User                @relation("SellerAuctions", fields: [sellerId], references: [id], onDelete: Cascade)
  currentWinner User?               @relation("WinnerAuctions", fields: [currentWinnerId], references: [id])
  category      Category?           @relation(fields: [categoryId], references: [id])
  bids          Bid[]
  chatMessages  ChatMessage[]
  ratings       Rating[]
  transactions  WalletTransaction[]
  mutedUsers    AuctionMute[]

  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@map("auctions")
}

enum AuctionStatus {
  draft
  scheduled
  live
  ended
  completed
  cancelled
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String   @map("auction_id")
  userId    String   @map("user_id")
  amount    Decimal  @db.Decimal(12, 2)
  placedAt  DateTime @default(now()) @map("placed_at")

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([userId])
  @@map("bids")
}

model ChatMessage {
  id        String   @id @default(uuid())
  auctionId String   @map("auction_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@map("chat_messages")
}

model Rating {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  auctionId  String   @map("auction_id")
  score      Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser User    @relation("RatingsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("RatingsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  auction  Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, auctionId])
  @@map("ratings")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model AuctionMute {
  id        String   @id @default(uuid())
  auctionId String   @map("auction_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([auctionId, userId])
  @@map("auction_mutes")
}
